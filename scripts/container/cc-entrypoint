#!/bin/bash
# cc-entrypoint — Phase 1: Root setup, then hand off to developer
# Mounted at /usr/local/bin/cc-entrypoint
#
# Contract:
#   Phase 1 (this script, runs as root):
#     - Token setup
#     - Locale check
#     - Create developer user
#     - Docker socket permissions
#     - Sudo/rootish setup
#     - Install fin command
#     - Stage files for developer (gitconfig)
#     - exec as developer → cc-developer-setup
#
#   Phase 2+3 happen in cc-developer-setup (runs as developer)
#
# NO set -e. Every non-critical operation uses || true.

# ============================================================================
# Privilege drop helper — works with any base image
# ============================================================================
# Tries gosu (best), then su (most images), then sudo, then runs directly.
_exec_as_developer() {
    if command -v gosu >/dev/null 2>&1; then
        exec gosu developer "$@"
    elif command -v su >/dev/null 2>&1; then
        exec su -s /bin/bash developer -c "$(printf '%q ' "$@")"
    elif command -v sudo >/dev/null 2>&1; then
        exec sudo -u developer -E -- "$@"
    else
        # No privilege drop available — run as current user with warning
        echo "WARNING: no gosu/su/sudo — running as $(whoami)" >&2
        exec "$@"
    fi
}

# For inline bash commands (bash -c "...")
_exec_as_developer_bash() {
    if command -v gosu >/dev/null 2>&1; then
        exec gosu developer bash -c "$1"
    elif command -v su >/dev/null 2>&1; then
        exec su -s /bin/bash developer -c "$1"
    elif command -v sudo >/dev/null 2>&1; then
        exec sudo -u developer -E bash -c "$1"
    else
        echo "WARNING: no gosu/su/sudo — running as $(whoami)" >&2
        exec bash -c "$1"
    fi
}

# ============================================================================
# Token Setup
# ============================================================================

if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN_NESTED:-}" ]]; then
    export CLAUDE_CODE_OAUTH_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN_NESTED"
elif [[ -f /run/secrets/claude_token ]]; then
    export CLAUDE_CODE_OAUTH_TOKEN=$(cat /run/secrets/claude_token)
else
    echo "ERROR: No token found (neither CLAUDE_CODE_OAUTH_TOKEN_NESTED env var nor /run/secrets/claude_token)" >&2
    exit 1
fi

# ============================================================================
# Locale Check
# ============================================================================

if [[ -n "${LC_ALL:-}" ]] && ! locale -a 2>/dev/null | grep -qi "${LC_ALL%%.*}"; then
    echo "WARNING: locale '$LC_ALL' not available — add 'locales' package and 'locale-gen $LC_ALL' to your Dockerfile"
    unset LC_ALL
fi

# ============================================================================
# Overlay Setup (deprecated, retained for compat)
# ============================================================================

HOST_UID=${HOST_UID:-1000}
DEV_GID=61000

if [[ "${USE_OVERLAY:-}" == "1" ]]; then
    echo "Setting up overlay filesystem..."
    mkdir -p /session-data/upper /session-data/work
    rmdir /workspace 2>/dev/null || rm -f /workspace 2>/dev/null || true
    mkdir -p /workspace
    if fuse-overlayfs \
        -o lowerdir=/workspace-lower,upperdir=/session-data/upper,workdir=/session-data/work \
        /workspace 2>&1; then
        echo "  Overlay mounted at /workspace"
    else
        mount --bind /workspace-lower /workspace 2>/dev/null || ln -sf /workspace-lower /workspace
        echo "  Fallback: direct mount, read-only"
    fi
    cd /workspace
    echo ""
fi

# ============================================================================
# User Setup (must happen BEFORE any early exit that uses gosu developer)
# ============================================================================

DEV_GID=61000
HOST_UID="${HOST_UID:-1000}"

if [[ "${RUN_AS_USER:-}" == "1" ]] || [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
    groupadd -g $DEV_GID developer 2>/dev/null || true
    useradd -u $HOST_UID -g $DEV_GID -m -s /bin/bash developer 2>/dev/null || true
    chown -R developer:developer /workspace 2>/dev/null || true
    # Fix volume mount ownership — Docker creates volume roots as root.
    # Recursively fix /home/developer to catch all volume mounts and caches
    # (.claude, .cargo, .npm, .cache, .cabal, .ghcup, .local, etc.)
    chown -R developer:developer /home/developer 2>/dev/null || true

    # Make root-installed tool binaries accessible to developer.
    # Dockerfiles install to /root/.ghcup, /root/.bun, etc. — developer
    # can't traverse /root/ without this.
    chmod a+rx /root 2>/dev/null || true

    # Redirect writable state to developer-owned paths (volumes).
    # Binaries stay at their install location; only caches/registries move.
    export CARGO_HOME=/home/developer/.cargo
    export CABAL_DIR=/home/developer/.cabal
    export STACK_ROOT=/home/developer/.stack
    export GHCUP_INSTALL_BASE_PREFIX=/home/developer
    export NPM_CONFIG_CACHE=/home/developer/.npm
    export PIP_CACHE_DIR=/home/developer/.cache/pip
    export BUN_INSTALL_CACHE_DIR=/home/developer/.cache/bun

    # Add common tool binary paths — covers ghcup, bun, local installs
    for p in /root/.ghcup/bin /root/.bun/bin /root/.local/bin /home/developer/.cargo/bin /home/developer/.local/bin /home/developer/.ghcup/bin; do
        [[ -d "$p" ]] && export PATH="$p:$PATH"
    done
fi

# ============================================================================
# Verify Mode (early exit)
# ============================================================================

if [[ "${VERIFY_MODE:-}" == "1" ]]; then
    echo "=== Verification ==="
    echo "Run as: $(if [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then echo "developer (sudo)"; elif [[ "${RUN_AS_USER:-}" == "1" ]]; then echo "developer"; else echo "root"; fi)"
    echo "Claude: $(which claude 2>&1)"
    echo "Platform: ${PLATFORM:-unknown}"
    echo ""
    echo "=== Token Check ==="
    if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
        if [[ -f /run/secrets/claude_token ]]; then
            echo "  Token source: file"
        elif [[ -n "${CLAUDE_CODE_OAUTH_TOKEN_NESTED:-}" ]]; then
            echo "  Token source: nested env var"
        else
            echo "  Token source: environment"
        fi
        echo "  Token: ${CLAUDE_CODE_OAUTH_TOKEN:0:20}..."
    else
        echo "  Token missing"
        exit 1
    fi
    echo ""
    echo "=== Claude Test ==="
    HOME=/home/developer claude --print "test" 2>&1 | head -5
    exit 0
fi

# ============================================================================
# Shell-Only Mode (early exit)
# ============================================================================

if [[ "${SHELL_ONLY:-}" == "1" ]]; then
    WORK_DIR="/workspace"
    if [[ -f /workspace/.main-project ]]; then
        MAIN_PROJ=$(cat /workspace/.main-project)
        [[ -d "/workspace/$MAIN_PROJ" ]] && WORK_DIR="/workspace/$MAIN_PROJ"
    fi
    if [[ "${RUN_AS_USER:-}" == "1" ]] || [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
        _exec_as_developer_bash "export CLAUDE_CODE_OAUTH_TOKEN='$CLAUDE_CODE_OAUTH_TOKEN' && cd $WORK_DIR && exec bash"
    else
        exec bash -c "cd $WORK_DIR && exec bash"
    fi
fi

# ============================================================================
# Bash Exec Mode (early exit)
# ============================================================================

if [[ -n "${BASH_EXEC:-}" ]]; then
    WORK_DIR="/workspace"
    if [[ -f /workspace/.main-project ]]; then
        MAIN_PROJ=$(cat /workspace/.main-project)
        [[ -d "/workspace/$MAIN_PROJ" ]] && WORK_DIR="/workspace/$MAIN_PROJ"
    fi
    cd "$WORK_DIR"
    if [[ "${RUN_AS_USER:-}" == "1" ]] || [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
        _exec_as_developer_bash "$BASH_EXEC"
    else
        exec bash -c "$BASH_EXEC"
    fi
fi

# ============================================================================
# User Setup (continued — sudo, docker socket, etc.)
# ============================================================================

if [[ "${RUN_AS_USER:-}" == "1" ]] || [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
    # User already created above (before early exits)

    # Docker socket permissions
    if [[ -S /var/run/docker.sock ]]; then
        chmod 666 /var/run/docker.sock 2>/dev/null || true
    fi

    # Sudo setup for rootish mode
    if [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
        if ! command -v sudo &>/dev/null; then
            echo "WARNING: sudo not found - rootish mode requires sudo in the image"
            echo "         Use --dockerfile to build an image with sudo, or use --as-root"
        else
            echo "developer ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/developer
            chmod 0440 /etc/sudoers.d/developer

            cat > /usr/local/bin/rootish << 'WRAPPER'
#!/bin/bash
exec sudo "$@"
WRAPPER
            chmod +x /usr/local/bin/rootish
        fi
    fi
fi

# Check for docker CLI if socket is mounted
if [[ -S /var/run/docker.sock ]] && ! command -v docker &>/dev/null; then
    echo "WARNING: docker socket mounted but docker CLI not found"
    echo "         Use --dockerfile to build an image with docker"
fi

# ============================================================================
# Install fin command
# ============================================================================

cat > /usr/local/bin/fin << 'FINSCRIPT'
#!/bin/bash
if [[ $# -eq 0 ]]; then
    echo "Usage: fin <description>"
    echo "Signals completion of conflict resolution and terminates the session."
    exit 1
fi
echo "$*" > /workspace/.reconcile-complete
echo ""
echo "Session complete: $*"
kill 1
FINSCRIPT
chmod +x /usr/local/bin/fin

# ============================================================================
# Stage files for developer
# ============================================================================

# Copy gitconfig to /tmp so developer can pick it up (avoids chown)
if [[ -f /root/.gitconfig ]]; then
    cp /root/.gitconfig /tmp/.gitconfig-source 2>/dev/null || true
    chmod 644 /tmp/.gitconfig-source 2>/dev/null || true
fi

# ============================================================================
# Ensure Claude Code is installed
# ============================================================================

if ! command -v claude >/dev/null 2>&1; then
    echo "  Installing Claude Code..."
    _install_ok=false
    if command -v npm >/dev/null 2>&1; then
        echo "  Using npm..." >&2
        if npm install -g @anthropic-ai/claude-code 2>&1; then
            _install_ok=true
        fi
    fi
    if [[ "$_install_ok" != "true" ]] && command -v curl >/dev/null 2>&1; then
        echo "  Using curl installer..." >&2
        if curl -fsSL https://claude.ai/install.sh | bash 2>&1; then
            # curl installer puts claude in ~/.local/bin — add to PATH
            export PATH="$HOME/.local/bin:$PATH"
            _install_ok=true
        fi
    fi
    if [[ "$_install_ok" != "true" ]]; then
        echo "ERROR: Failed to install Claude Code" >&2
        echo "  Neither npm nor curl install succeeded." >&2
        echo "  Add Node.js/npm to your Dockerfile, or use the base image:" >&2
        echo "  FROM ghcr.io/hypermemetic/claude-container:latest" >&2
        exit 1
    fi
    # Verify it's actually available
    if ! command -v claude >/dev/null 2>&1; then
        echo "ERROR: Claude Code installed but 'claude' not found in PATH" >&2
        echo "  PATH=$PATH" >&2
        exit 1
    fi
fi

# ============================================================================
# Hand off to developer setup (Phase 2 + 3)
# ============================================================================

# cc-developer-setup does config setup then execs cc-agent-run
if [[ "${RUN_AS_USER:-}" == "1" ]] || [[ "${RUN_AS_ROOTISH:-}" == "1" ]]; then
    _exec_as_developer /usr/local/bin/cc-developer-setup
else
    # Pure root mode: run developer setup directly (HOME set for claude)
    HOME=/home/developer exec /usr/local/bin/cc-developer-setup
fi
